# TalentLens Backend — Environment Variables
# Copy this file to .env and fill in your API keys

# OpenAI API Key (gpt-4o-mini)
OPENAI_API_KEY=your_openai_api_key_here

# Groq API Key (ultra-fast inference)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (fallback AI provider)
GEMINI_API_KEY=your_gemini_api_key_here

# Delay between AI calls (seconds) — prevents rate limiting
AI_CALL_DELAY=1.5

# Database URL (defaults to local SQLite)
# DATABASE_URL=sqlite:///./data/talentlens.db
